{
  "name": "tizenbrew-romm",
  "version": "1.0.1",
  "description": "TizenBrew wrapper for RomM — self-hosted ROM manager",
  "packageType": "mods",
  "appName": "RomM",
  "websiteURL": "http://192.168.1.101:3333/console",
  "main": "index.js",
  "evaluateScriptOnDocumentStart": true,
  "keys": [
    "ArrowUp",
    "ArrowDown",
    "ArrowLeft",
    "ArrowRight",
    "Enter",
    "Return",
    "XF86Back",
    "XF86AudioPlay",
    "XF86AudioPause",
    "XF86AudioStop",
    "XF86PlayBack"
  ],
